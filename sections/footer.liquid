<footer class="sa-footer" role="contentinfo">
  <div class="sa-footer__inner">

    <!-- Brand column -->
    <div>
      <p class="sa-footer__brand-name">{{ shop.name }}</p>
      <p class="sa-footer__brand-desc">Luxury streetwear &amp; sneakers curated in Macon, GA. Authenticated, in-hand, and ready to ship.</p>
      <div class="sa-footer__social">
        {%- if settings.instagram_url != blank -%}
          <a href="{{ settings.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">Instagram</a>
        {%- endif -%}
        {%- if settings.facebook_url != blank -%}
          <a href="{{ settings.facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook">Facebook</a>
        {%- endif -%}
        {%- if settings.tiktok_url != blank -%}
          <a href="{{ settings.tiktok_url }}" target="_blank" rel="noopener" aria-label="TikTok">TikTok</a>
        {%- endif -%}
      </div>
    </div>

    <!-- Shop -->
    <div>
      <p class="sa-footer__col-title">Shop</p>
      <div class="sa-footer__col-links">
        <a href="/collections/new-arrivals">New Arrivals</a>
        <a href="/collections/sneakers">Sneakers</a>
        <a href="/collections/clothing">Clothing</a>
        <a href="/collections/vintage-pieces">Vintage</a>
        <a href="/pages/shop-by-size">Shop by Size</a>
        <a href="/collections/sixth-ave">Sixth Ave</a>
        <a href="/products/sixth-ave-gift-card">Gift Cards</a>
      </div>
    </div>

    <!-- Info -->
    <div>
      <p class="sa-footer__col-title">Info</p>
      <div class="sa-footer__col-links">
        <a href="/pages/contact">Contact</a>
        <a href="/policies/shipping-policy">Shipping</a>
        <a href="/policies/refund-policy">Returns</a>
        <a href="/policies/privacy-policy">Privacy</a>
        <a href="/policies/terms-of-service">Terms</a>
        <a href="/search">Search</a>
      </div>
    </div>

    <!-- Locations -->
    <div>
      <p class="sa-footer__col-title">Visit Us</p>
      <div class="sa-footer__col-links" style="font-size:12px; color: var(--sa-muted); line-height: 1.8">
        <strong style="color: var(--sa-white); font-size: 11px; letter-spacing: .08em; text-transform: uppercase;">Downtown Flagship</strong><br>
        482 1st Street<br>Macon, GA 31201<br>
        <span style="font-size:11px">Mon–Thu 12–7 · Fri–Sat 11–8</span>
        <br><br>
        <strong style="color: var(--sa-white); font-size: 11px; letter-spacing: .08em; text-transform: uppercase;">River Crossing</strong><br>
        5080 Riverside Dr #408<br>Macon, GA<br>
        <span style="font-size:11px">Mon–Thu 11–7 · Fri–Sat 10–8 · Sun 12–6</span>
      </div>
    </div>

  </div>

  <div class="sa-footer__bottom">
    <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</span>
    <div style="display:flex; gap: 16px">
      <a href="/policies/privacy-policy">Privacy</a>
      <a href="/policies/terms-of-service">Terms</a>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "sa-section-footer",
  "limit": 1,
  "settings": [],
  "enabled_on": { "groups": ["footer"] }
}
{% endschema %}
