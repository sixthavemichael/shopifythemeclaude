<div style="max-width: 760px; margin: 0 auto; padding: 60px 24px">
  <p style="font-size:10px; letter-spacing:.14em; text-transform:uppercase; color: var(--sa-muted); margin-bottom:12px">
    <a href="{{ blog.url }}" style="color: var(--sa-muted)">{{ blog.title }}</a> &nbsp;/&nbsp; {{ article.published_at | date: '%B %d, %Y' }}
  </p>
  <h1 style="font-size:clamp(22px,4vw,36px); font-weight:300; letter-spacing:.1em; text-transform:uppercase; margin-bottom:32px; line-height:1.2">{{ article.title }}</h1>
  {%- if article.image -%}
    <div style="aspect-ratio:16/9; overflow:hidden; margin-bottom:36px">
      <img src="{{ article.image | image_url: width: 1200 }}" alt="{{ article.image.alt | default: article.title | escape }}" style="width:100%; height:100%; object-fit:cover" loading="eager">
    </div>
  {%- endif -%}
  <div style="font-size:14px; color: var(--sa-muted); line-height:1.9; letter-spacing:.02em">{{ article.content }}</div>
</div>

{% schema %}
{
  "name": "Article page",
  "tag": "div",
  "settings": [],
  "presets": [{ "name": "Article page" }]
}
{% endschema %}
