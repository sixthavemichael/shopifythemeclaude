<div class="sa-trust">
  {%- for block in section.blocks -%}
    <div class="sa-trust__item" {{ block.shopify_attributes }}>
      {%- if block.settings.icon == 'shield' -%}
        <div class="sa-trust__icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 2L4 6v8c0 6 4.5 10.5 10 12 5.5-1.5 10-6 10-12V6L14 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 14l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
      {%- elsif block.settings.icon == 'truck' -%}
        <div class="sa-trust__icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="1" y="7" width="17" height="12" rx="1" stroke="currentColor" stroke-width="1.5"/><path d="M18 10h5l3 4v5h-8V10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><circle cx="7" cy="21" r="2" stroke="currentColor" stroke-width="1.5"/><circle cx="22" cy="21" r="2" stroke="currentColor" stroke-width="1.5"/></svg>
        </div>
      {%- elsif block.settings.icon == 'refresh' -%}
        <div class="sa-trust__icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M4 14a10 10 0 1018.7-4.9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M23 4v5h-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
      {%- elsif block.settings.icon == 'store' -%}
        <div class="sa-trust__icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M3 11l2-7h18l2 7" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><rect x="3" y="11" width="22" height="13" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="10" y="16" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.5"/></svg>
        </div>
      {%- endif -%}
      {%- if block.settings.label != blank -%}
        <p class="sa-trust__label">{{ block.settings.label }}</p>
      {%- endif -%}
      {%- if block.settings.title != blank -%}
        <p class="sa-trust__title">{{ block.settings.title }}</p>
      {%- endif -%}
      {%- if block.settings.body != blank -%}
        <p class="sa-trust__body">{{ block.settings.body }}</p>
      {%- endif -%}
    </div>
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "Trust strip",
  "tag": "div",
  "settings": [],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "limit": 4,
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [{ "value": "shield", "label": "Shield (Authentication)" }, { "value": "truck", "label": "Truck (Shipping)" }, { "value": "refresh", "label": "Refresh (Returns)" }, { "value": "store", "label": "Store (In-Store)" }], "default": "shield" },
        { "type": "text", "id": "label", "label": "Eyebrow label", "default": "Guaranteed" },
        { "type": "text", "id": "title", "label": "Title", "default": "Expert Authentication" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "Every item verified by experts with 10+ years of experience and over 10,000 products authenticated." }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "trust_item", "settings": { "icon": "shield", "label": "Guaranteed", "title": "Expert Authentication", "body": "Every item verified by experts with 10+ years of experience and over 10,000 products authenticated." } },
      { "type": "trust_item", "settings": { "icon": "truck", "label": "Fast", "title": "Same-Day Shipping", "body": "All orders ship the same or next business day. UPS Ground to Overnight delivery available." } },
      { "type": "trust_item", "settings": { "icon": "store", "label": "In-Store", "title": "Buy, Sell & Trade", "body": "Bring in your clothing and sneakers any day. Cash and store credit offers on the spot." } }
    ]
  },
  "presets": [{ "name": "Trust strip" }]
}
{% endschema %}
