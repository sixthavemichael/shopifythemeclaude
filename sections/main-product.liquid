{%- assign product = product -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}

<div class="sa-product">

  <!-- Gallery -->
  <div class="sa-product__gallery">
    <div class="sa-product__main-img">
      {%- if product.featured_image -%}
        <img
          id="MainProductImage"
          src="{{ product.featured_image | image_url: width: 800 }}"
          srcset="{{ product.featured_image | image_url: width: 500 }} 500w, {{ product.featured_image | image_url: width: 800 }} 800w, {{ product.featured_image | image_url: width: 1100 }} 1100w"
          sizes="(max-width: 768px) 100vw, 50vw"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          loading="eager"
          fetchpriority="high"
        >
      {%- endif -%}
    </div>
    {%- if product.images.size > 1 -%}
      <div class="sa-product__thumbs">
        {%- for image in product.images limit: 8 -%}
          <div class="sa-product__thumb {% if forloop.first %}is-active{% endif %}"
            data-src="{{ image | image_url: width: 900 }}"
            data-srcset="{{ image | image_url: width: 500 }} 500w, {{ image | image_url: width: 900 }} 900w"
          >
            <img src="{{ image | image_url: width: 140 }}" alt="{{ image.alt | default: product.title | escape }}" loading="lazy" width="70" height="70">
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <!-- Product info -->
  <div class="sa-product__info">

    {%- if product.vendor != blank -%}
      <p class="sa-product__vendor">{{ product.vendor }}</p>
    {%- endif -%}

    <h1 class="sa-product__title">{{ product.title }}</h1>

    <div class="sa-product__price">
      {%- if current_variant.compare_at_price > current_variant.price -%}
        <s>{{ current_variant.compare_at_price | money }}</s>
      {%- endif -%}
      <span class="sa-product__price-current">{{ current_variant.price | money }}</span>
    </div>

    <!-- Badges -->
    <div class="sa-product__badges">
      {%- if product.tags contains '1-of-1' or product.tags contains '1 of 1' -%}
        <span class="sa-badge sa-badge--white">1 of 1</span>
      {%- endif -%}
      {%- if product.tags contains 'authenticated' -%}
        <span class="sa-badge sa-badge--gold">Authenticated</span>
      {%- endif -%}
      {%- if product.tags contains 'vintage' -%}
        <span class="sa-badge sa-badge--vintage">Vintage</span>
      {%- endif -%}
      {%- if product.tags contains 'new-drop' or product.tags contains 'new drop' -%}
        <span class="sa-badge sa-badge--new">New Drop</span>
      {%- endif -%}
    </div>

    <div class="sa-product__divider"></div>

    {%- unless product.has_only_default_variant -%}
      {%- for option in product.options_with_values -%}
        <p class="sa-product__option-label">{{ option.name }}</p>
        <div class="sa-product__variants">
          {%- for value in option.values -%}
            {%- assign variant_available = false -%}
            {%- for variant in product.variants -%}
              {%- if variant.option1 == value or variant.option2 == value or variant.option3 == value -%}
                {%- if variant.available -%}{%- assign variant_available = true -%}{%- endif -%}
              {%- endif -%}
            {%- endfor -%}
            <button
              class="sa-product__variant-btn {% if value == current_variant.option1 or value == current_variant.option2 %}is-selected{% endif %} {% unless variant_available %}is-unavailable{% endunless %}"
              data-option-name="{{ option.name }}"
              data-option-value="{{ value }}"
            >{{ value }}</button>
          {%- endfor -%}
        </div>
      {%- endfor -%}
    {%- endunless -%}

    <!-- Hidden variant selector (for JS) -->
    <select id="ProductVariantSelect" name="id" style="display:none">
      {%- for variant in product.variants -%}
        <option
          value="{{ variant.id }}"
          {% if variant == current_variant %}selected{% endif %}
          data-price="{{ variant.price }}"
          data-available="{{ variant.available }}"
        >{{ variant.title }}</option>
      {%- endfor -%}
    </select>

    <div class="sa-product__atc-wrap">
      {%- if current_variant.available -%}
        <button
          class="sa-btn sa-btn--primary sa-product__atc-btn"
          data-variant-id="{{ current_variant.id }}"
          onclick="SixthAve.quickAdd('{{ current_variant.id }}', this)"
        >Add to Cart</button>
      {%- else -%}
        <button class="sa-btn sa-btn--ghost sa-btn--full" disabled>Sold Out — Notify Me</button>
      {%- endif -%}
      <a href="/cart" class="sa-btn sa-btn--ghost">View Cart</a>
    </div>

    <!-- Installments hint -->
    <p style="font-size:11px; color: var(--sa-muted); letter-spacing:.04em; margin-top: 4px; text-align:center;">
      Buy now, pay later with <strong style="color:var(--sa-white)">Shop Pay</strong> or <strong style="color:var(--sa-white)">Afterpay</strong>
    </p>

    <!-- Trust items -->
    <div class="sa-product__trust">
      <div class="sa-product__trust-item">
        <div class="sa-product__trust-icon">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 1L2 4v5c0 4 3 6.8 7 8 4-1.2 7-4 7-8V4L9 1z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/><path d="M5.5 9l2.5 2.5 5-5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="sa-product__trust-text">
          <p class="sa-product__trust-title">100% Authenticated</p>
          <p class="sa-product__trust-body">Verified by experts with 10+ years experience and 10,000+ items authenticated.</p>
        </div>
      </div>
      <div class="sa-product__trust-item">
        <div class="sa-product__trust-icon">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="1" y="5" width="11" height="8" rx="1" stroke="currentColor" stroke-width="1.3"/><path d="M12 7h3l2 3v3h-5V7z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/><circle cx="5" cy="14" r="1.5" stroke="currentColor" stroke-width="1.3"/><circle cx="14" cy="14" r="1.5" stroke="currentColor" stroke-width="1.3"/></svg>
        </div>
        <div class="sa-product__trust-text">
          <p class="sa-product__trust-title">Ships Same or Next Day</p>
          <p class="sa-product__trust-body">Every item is in-hand. UPS Ground to Overnight available at checkout.</p>
        </div>
      </div>
      <div class="sa-product__trust-item">
        <div class="sa-product__trust-icon">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M1 9a8 8 0 1013-6.2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><path d="M17 1v5h-5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="sa-product__trust-text">
          <p class="sa-product__trust-title">Questions? Ask Us</p>
          <p class="sa-product__trust-body">All sales are final. Email or DM @6xth.ave before buying — we're happy to help with fit, condition, or details.</p>
        </div>
      </div>
    </div>

    <!-- Description accordion -->
    <div class="sa-product__accordion">
      {%- if product.description != blank -%}
        <div class="sa-product__accordion-item">
          <button class="sa-product__accordion-btn">
            Description
            <svg class="sa-accordion-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" style="transition: transform .25s ease"><path d="M2 5l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div class="sa-product__accordion-body">
            <div class="sa-product__desc">{{ product.description }}</div>
          </div>
        </div>
      {%- endif -%}
      <div class="sa-product__accordion-item">
        <button class="sa-product__accordion-btn">
          Shipping &amp; Returns
          <svg class="sa-accordion-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" style="transition: transform .25s ease"><path d="M2 5l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="sa-product__accordion-body">
          <p>Orders ship same or next business day via UPS. Select your speed at checkout — Ground to Overnight available. All sales are final. Please reach out before purchasing if you have questions.</p>
        </div>
      </div>
      <div class="sa-product__accordion-item">
        <button class="sa-product__accordion-btn">
          Authentication
          <svg class="sa-accordion-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" style="transition: transform .25s ease"><path d="M2 5l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="sa-product__accordion-body">
          <p>Every item is carefully authenticated by our experts before hitting the shelves. 10+ years of experience and over 10,000 products verified. Shop confidently knowing everything is 100% legit.</p>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Related products -->
{%- assign related = product.collections.first.products | where: 'available', true -%}
{%- if related.size > 1 -%}
  <div class="sa-related">
    <div class="sa-related sa-section__inner" style="padding:0">
      <div class="sa-section__header"><h2 class="sa-section__title">You May Also Like</h2></div>
      <div class="sa-grid">
        {%- for p in related limit: 4 -%}
          {%- unless p.id == product.id -%}
            {%- render 'product-card', product: p -%}
          {%- endunless -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Product page",
  "tag": "div",
  "settings": [],
  "presets": [{ "name": "Product page" }]
}
{% endschema %}
