<div style="max-width:900px; margin:0 auto; padding:60px 24px">
  <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:40px">
    <h1 style="font-size:22px; font-weight:300; letter-spacing:.14em; text-transform:uppercase">My Account</h1>
    <a href="{{ routes.account_logout_url }}" class="sa-btn sa-btn--ghost sa-btn--sm">Sign Out</a>
  </div>

  <p style="font-size:13px; color: var(--sa-muted); margin-bottom:32px">{{ customer.first_name }} {{ customer.last_name }} &mdash; {{ customer.email }}</p>

  <h2 style="font-size:13px; font-weight:500; letter-spacing:.12em; text-transform:uppercase; color: var(--sa-white); margin-bottom:20px">Order History</h2>

  {%- if customer.orders.size > 0 -%}
    {%- for order in customer.orders -%}
      <div style="border-top:.5px solid var(--sa-border); padding:20px 0; display:grid; grid-template-columns:1fr 1fr 1fr auto; gap:16px; align-items:center">
        <div>
          <p style="font-size:11px; letter-spacing:.1em; text-transform:uppercase; color: var(--sa-muted); margin-bottom:3px">Order</p>
          <a href="{{ order.customer_url }}" style="font-size:13px; color: var(--sa-white)">#{{ order.name }}</a>
        </div>
        <div>
          <p style="font-size:11px; letter-spacing:.1em; text-transform:uppercase; color: var(--sa-muted); margin-bottom:3px">Date</p>
          <p style="font-size:13px; color: var(--sa-white)">{{ order.created_at | date: '%B %d, %Y' }}</p>
        </div>
        <div>
          <p style="font-size:11px; letter-spacing:.1em; text-transform:uppercase; color: var(--sa-muted); margin-bottom:3px">Total</p>
          <p style="font-size:13px; color: var(--sa-white)">{{ order.total_price | money }}</p>
        </div>
        <span style="font-size:10px; letter-spacing:.1em; text-transform:uppercase; color: var(--sa-gold)">{{ order.financial_status }}</span>
      </div>
    {%- endfor -%}
  {%- else -%}
    <p style="font-size:13px; color: var(--sa-muted); padding:24px 0">No orders yet. <a href="/collections/all" style="color: var(--sa-white); text-decoration:underline; text-underline-offset:2px">Start shopping</a>.</p>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Account page",
  "tag": "div",
  "settings": [],
  "presets": [{ "name": "Account page" }]
}
{% endschema %}
