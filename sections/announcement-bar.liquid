{%- if section.settings.show_announcement -%}
<div class="sa-ann" role="region" aria-label="Announcement">
  <div class="sa-ann__track">
    {%- for block in section.blocks -%}
      <div class="sa-ann__slide" {{ block.shopify_attributes }}>
        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}">{{ block.settings.text }}</a>
        {%- else -%}
          {{ block.settings.text }}
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "class": "sa-section-announcement",
  "limit": 1,
  "settings": [
    { "type": "checkbox", "id": "show_announcement", "label": "Show announcement bar", "default": true }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "limit": 5,
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "✦  FREE SHIPPING ON ORDERS $150+  ✦" },
        { "type": "url", "id": "link", "label": "Link (optional)" }
      ]
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
