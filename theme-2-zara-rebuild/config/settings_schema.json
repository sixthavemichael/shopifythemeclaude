[
  {
    "name": "theme_info",
    "theme_name": "Sixth Ave",
    "theme_version": "1.0.0",
    "theme_author": "Sixth Ave",
    "theme_documentation_url": "https://shopsixthave.com",
    "theme_support_url": "https://shopsixthave.com"
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 60,
        "max": 200,
        "step": 4,
        "unit": "px",
        "label": "Logo width",
        "default": 100
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image"
      }
    ]
  },
  {
    "name": "Navigation",
    "settings": [
      {
        "type": "link_list",
        "id": "main_menu",
        "label": "Main menu",
        "default": "main-menu"
      },
      {
        "type": "link_list",
        "id": "footer_menu_1",
        "label": "Footer menu — Shop",
        "default": "footer"
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "url",
        "id": "instagram_url",
        "label": "Instagram URL"
      },
      {
        "type": "url",
        "id": "facebook_url",
        "label": "Facebook URL"
      },
      {
        "type": "url",
        "id": "tiktok_url",
        "label": "TikTok URL"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "checkbox",
        "id": "cart_drawer",
        "label": "Enable cart drawer",
        "default": true
      }
    ]
  }
]
