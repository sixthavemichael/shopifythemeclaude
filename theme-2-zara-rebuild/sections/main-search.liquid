<div class="sa-search-results">
  {%- if search.performed -%}
    <h1 class="sa-search-results__title">
      {%- if search.results_count == 0 -%}
        No results for &ldquo;{{ search.terms | escape }}&rdquo;
      {%- else -%}
        {{ search.results_count }} result{% if search.results_count != 1 %}s{% endif %} for &ldquo;{{ search.terms | escape }}&rdquo;
      {%- endif -%}
    </h1>
    {%- if search.results_count > 0 -%}
      <div class="sa-grid">
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            {%- render 'product-card', product: item -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <div style="padding: 40px 0; text-align: center">
        <p style="color: var(--sa-muted); font-size: 13px; margin-bottom: 24px">Try searching for a brand, style, or size.</p>
        <a href="/collections/all" class="sa-btn sa-btn--primary">Browse All Products</a>
      </div>
    {%- endif -%}
  {%- else -%}
    <form action="/search" method="get" style="max-width: 560px; margin: 0 auto">
      <input type="hidden" name="type" value="product">
      <div class="sa-email__form">
        <input class="sa-email__input" type="search" name="q" placeholder="Search sneakers, brands, tees..." autocomplete="off">
        <button type="submit" class="sa-btn sa-btn--primary">Search</button>
      </div>
    </form>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Search page",
  "tag": "div",
  "settings": [],
  "presets": [{ "name": "Search page" }]
}
{% endschema %}
