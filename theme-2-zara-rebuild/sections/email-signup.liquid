<section class="sa-email">
  {%- if section.settings.eyebrow != blank -%}
    <p class="sa-email__eyebrow">{{ section.settings.eyebrow }}</p>
  {%- endif -%}
  <h2 class="sa-email__heading">{{ section.settings.heading }}</h2>
  {%- if section.settings.subheading != blank -%}
    <p class="sa-email__sub">{{ section.settings.subheading }}</p>
  {%- endif -%}

  {%- form 'customer', id: 'EmailSignupForm' -%}
    <input type="hidden" name="contact[tags]" value="newsletter">
    <div class="sa-email__form">
      <input
        class="sa-email__input"
        type="email"
        name="contact[email]"
        placeholder="{{ section.settings.placeholder | default: 'Your email address' }}"
        required
        autocomplete="email"
      >
      <button type="submit" class="sa-btn sa-btn--primary">{{ section.settings.button_label | default: 'Subscribe' }}</button>
    </div>
    {%- if form.posted_successfully? -%}
      <p style="color: var(--sa-gold); font-size: 12px; letter-spacing: .1em; text-transform: uppercase; margin-top: 14px;">You're on the list. New drops coming your way.</p>
    {%- endif -%}
  {%- endform -%}
</section>

{% schema %}
{
  "name": "Email signup",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "First Access" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get new drops before they sell out." },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Join the list. No noise — just drops, restocks, and exclusive first access." },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Your email address" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Subscribe" }
  ],
  "presets": [{ "name": "Email signup" }]
}
{% endschema %}
