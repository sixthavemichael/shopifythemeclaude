<div style="max-width:900px; margin:0 auto; padding:60px 24px">
  <p style="font-size:11px; letter-spacing:.1em; text-transform:uppercase; color: var(--sa-muted); margin-bottom:16px">
    <a href="/account" style="color: var(--sa-muted)">Account</a> &nbsp;/&nbsp; Order {{ order.name }}
  </p>
  <h1 style="font-size:22px; font-weight:300; letter-spacing:.14em; text-transform:uppercase; margin-bottom:8px">Order {{ order.name }}</h1>
  <p style="font-size:12px; color: var(--sa-muted); margin-bottom:40px">Placed {{ order.created_at | date: '%B %d, %Y' }}</p>

  {%- for line_item in order.line_items -%}
    <div style="display:grid; grid-template-columns:80px 1fr auto; gap:20px; align-items:center; border-top:.5px solid var(--sa-border); padding:20px 0">
      {%- if line_item.image -%}
        <img src="{{ line_item.image | image_url: width: 160 }}" alt="{{ line_item.title | escape }}" style="width:80px; height:80px; object-fit:cover">
      {%- else -%}
        <div style="width:80px; height:80px; background: var(--sa-card)"></div>
      {%- endif -%}
      <div>
        <p style="font-size:13px; color: var(--sa-white); margin-bottom:4px">{{ line_item.product.title }}</p>
        {%- unless line_item.variant.title == 'Default Title' -%}
          <p style="font-size:11px; color: var(--sa-muted)">{{ line_item.variant.title }}</p>
        {%- endunless -%}
        <p style="font-size:11px; color: var(--sa-muted); margin-top:4px">Qty: {{ line_item.quantity }}</p>
      </div>
      <p style="font-size:13px; color: var(--sa-white)">{{ line_item.final_price | money }}</p>
    </div>
  {%- endfor -%}

  <div style="border-top:.5px solid var(--sa-border); padding-top:24px; margin-top:8px; max-width:300px; margin-left:auto">
    <div style="display:flex; justify-content:space-between; font-size:12px; color: var(--sa-muted); margin-bottom:8px">
      <span>Subtotal</span>
      <span>{{ order.subtotal_price | money }}</span>
    </div>
    {%- for shipping_method in order.shipping_methods -%}
      <div style="display:flex; justify-content:space-between; font-size:12px; color: var(--sa-muted); margin-bottom:8px">
        <span>{{ shipping_method.title }}</span>
        <span>{{ shipping_method.price | money }}</span>
      </div>
    {%- endfor -%}
    <div style="display:flex; justify-content:space-between; font-size:14px; color: var(--sa-white); font-weight:400; border-top:.5px solid var(--sa-border); padding-top:12px; margin-top:4px">
      <span>Total</span>
      <span>{{ order.total_price | money }}</span>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Order page",
  "tag": "div",
  "settings": [],
  "presets": [{ "name": "Order page" }]
}
{% endschema %}
