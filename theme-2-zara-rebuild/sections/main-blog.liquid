<div style="max-width: 1100px; margin: 0 auto; padding: 60px 24px">
  <h1 style="font-size: clamp(20px,3vw,30px); font-weight:300; letter-spacing:.12em; text-transform:uppercase; margin-bottom: 40px">{{ blog.title }}</h1>
  <div style="display:grid; grid-template-columns: repeat(3,1fr); gap: 32px">
    {%- for article in blog.articles -%}
      <a href="{{ article.url }}" style="display:block; text-decoration:none">
        {%- if article.image -%}
          <div style="aspect-ratio:3/2; overflow:hidden; background: var(--sa-card); margin-bottom:16px">
            <img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.image.alt | default: article.title | escape }}" style="width:100%; height:100%; object-fit:cover" loading="lazy">
          </div>
        {%- endif -%}
        <p style="font-size:10px; letter-spacing:.14em; text-transform:uppercase; color: var(--sa-muted); margin-bottom:6px">{{ article.published_at | date: '%B %d, %Y' }}</p>
        <h2 style="font-size:15px; font-weight:500; letter-spacing:.04em; text-transform:uppercase; color: var(--sa-white); margin-bottom:8px">{{ article.title }}</h2>
        <p style="font-size:12px; color: var(--sa-muted); line-height:1.7">{{ article.excerpt | strip_html | truncate: 120 }}</p>
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Blog page",
  "tag": "div",
  "settings": [],
  "presets": [{ "name": "Blog page" }]
}
{% endschema %}
