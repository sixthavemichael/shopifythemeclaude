<div style="max-width:480px; margin:80px auto; padding:0 24px">
  <h1 style="font-size:22px; font-weight:300; letter-spacing:.14em; text-transform:uppercase; margin-bottom:32px; text-align:center">Create Account</h1>

  {%- form 'create_customer' -%}
    {%- if form.errors -%}
      <p style="color:#e24b4a; font-size:12px; margin-bottom:16px; text-align:center">{{ form.errors | default_errors }}</p>
    {%- endif -%}
    <div style="display:flex; flex-direction:column; gap:12px; margin-bottom:20px">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px">
        <input class="sa-form-input" type="text" name="customer[first_name]" placeholder="First name" autocomplete="given-name" style="width:100%">
        <input class="sa-form-input" type="text" name="customer[last_name]" placeholder="Last name" autocomplete="family-name" style="width:100%">
      </div>
      <input class="sa-form-input" type="email" name="customer[email]" placeholder="Email address" autocomplete="email" required style="width:100%">
      <input class="sa-form-input" type="password" name="customer[password]" placeholder="Password" autocomplete="new-password" required style="width:100%">
    </div>
    <button type="submit" class="sa-btn sa-btn--primary sa-btn--full" style="margin-bottom:12px">Create Account</button>
    <p style="text-align:center; font-size:11px; color: var(--sa-muted)">Already have an account? <a href="/account/login" style="color: var(--sa-muted); text-decoration:underline; text-underline-offset:2px">Sign in</a></p>
  {%- endform -%}
</div>

{% schema %}
{
  "name": "Register page",
  "tag": "div",
  "settings": [],
  "presets": [{ "name": "Register page" }]
}
{% endschema %}
