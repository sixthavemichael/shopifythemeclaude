<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ shop.name }} — Coming Soon</title>
  {{ content_for_header }}
  {{ 'sixth-ave.css' | asset_url | stylesheet_tag }}
  <style>
    body { background: #fff; color: #0a0a0a; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
    .pw { text-align: center; padding: 40px 24px; max-width: 440px; width: 100%; }
    .pw__logo { font-size: 18px; font-weight: 300; letter-spacing: .2em; text-transform: uppercase; margin-bottom: 40px; }
    .pw__title { font-size: 13px; font-weight: 400; letter-spacing: .14em; text-transform: uppercase; margin-bottom: 8px; }
    .pw__sub { font-size: 13px; color: #777; margin-bottom: 32px; line-height: 1.6; }
    .pw__form { display: flex; gap: 8px; }
    .pw__input { flex: 1; border: 1px solid rgba(0,0,0,.16); padding: 12px 16px; font-size: 13px; outline: none; letter-spacing: .04em; }
    .pw__input:focus { border-color: #0a0a0a; }
    .pw__btn { background: #0a0a0a; color: #fff; border: none; padding: 12px 20px; font-size: 11px; letter-spacing: .12em; text-transform: uppercase; cursor: pointer; }
    .pw__error { color: #c0392b; font-size: 12px; margin-top: 12px; }
  </style>
</head>
<body>
  <div class="pw">
    <p class="pw__logo">{{ shop.name }}</p>
    <h1 class="pw__title">Coming Soon</h1>
    <p class="pw__sub">We're getting ready. Enter the password to preview the store.</p>
    {%- form 'storefront_password' -%}
      <div class="pw__form">
        <input class="pw__input" type="password" name="password" placeholder="Password" autocomplete="current-password">
        <button type="submit" class="pw__btn">Enter</button>
      </div>
      {%- if form.errors -%}
        <p class="pw__error">Wrong password. Try again.</p>
      {%- endif -%}
    {%- endform -%}
  </div>
  {{ content_for_layout }}
</body>
</html>
